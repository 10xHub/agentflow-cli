#################################
###### App Config ###############
#################################
APP_NAME="$agent_name"
APP_VERSION="0.1.0"
MODE="production"
LOG_LEVEL="INFO"
IS_DEBUG="false"
SUMMARY="$agent_name Backend"

#################################
###### CORS Config ##############
#################################
# TODO: In production, restrict origins and allowed hosts
ORIGINS="*"
ALLOWED_HOST="*"

#################################
###### Paths ####################
#################################
ROOT_PATH="/"
# Disable docs in production for security
DOCS_PATH="/docs"
REDOCS_PATH="/redoc"

#################################
###### Request Limits ###########
#################################
MAX_REQUEST_SIZE=10485760  # 10MB

#################################
###### Security Headers #########
#################################
SECURITY_HEADERS_ENABLED="true"
HSTS_ENABLED="true"
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS="true"
HSTS_PRELOAD="false"
FRAME_OPTIONS="DENY"
CONTENT_TYPE_OPTIONS="nosniff"
XSS_PROTECTION="1; mode=block"
REFERRER_POLICY="strict-origin-when-cross-origin"

#################################
###### Snowflake ID Config ######
#################################
SNOWFLAKE_EPOCH=1609459200000
SNOWFLAKE_NODE_ID=1
SNOWFLAKE_WORKER_ID=2

#################################
###### Sentry Config ############
#################################
SENTRY_DSN=""

##[IF_REDIS]##
#################################
###### Redis Config #############
#################################
REDIS_URL=""
##[/IF_REDIS]##

##[IF_JWT]##
#################################
###### JWT Config ###############
#################################
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
##[/IF_JWT]##

#################################
###### API Keys #################
#################################
GOOGLE_API_KEY=""
